# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# OpenAI / ChatGPT
CHATGPT_API_KEY=your_openai_api_key_here

# Server
PORT=3000
NODE_ENV=development

# Site password (leave empty for open access)
SITE_PASSWORD=

# WebSocket server URL (Railway)
# Leave empty for local dev (connects to same origin)
NEXT_PUBLIC_WS_URL=
